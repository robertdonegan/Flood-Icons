    "preview": "vite preview",
    "lint": "node scripts/lint-icons.mjs",
    "build:npm": "npm run manifest && node scripts/build-npm.mjs"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11"
  }
}